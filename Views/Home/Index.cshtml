@{
    Layout = "_Layout";
    ViewData["Title"] = "Dr. Cleiber Bueno";
}

<!-- HERO -->
<section class="hero" id="inicio">
    <div class="hero-left">
        <div class="hero-badge reveal"><span class="dot"></span>Consultas online disponíveis</div>
        <h1 class="reveal d1">Dr. Cleiber<br><em>Bueno Ferreira</em></h1>
        <p class="hero-sub reveal d2">Clínico Geral &amp; Médico do Trabalho</p>
        <p class="hero-crm reveal d2">CRM-MS 15182 · Dourados, MS</p>
        <div class="hero-pills reveal d3">
            <span class="pill">🏥 Urgência &amp; Emergência</span>
            <span class="pill">💊 Clínica Médica</span>
            <span class="pill">👷 Medicina do Trabalho</span>
            <span class="pill">💻 Telemedicina</span>
        </div>
        <div class="hero-actions reveal d4">
            <a href="#agendar" class="btn-g">📋 Agendar Consulta</a>
            <a href="#como-funciona" class="btn-o">Como funciona →</a>
        </div>
    </div>
    <div class="hero-right">
        <img src="~/images/FotoCleibin.jpeg" alt="Dr. Cleiber Bueno Ferreira">
        <div class="hero-plate">
            <div>
                <div class="plate-name">Dr. Cleiber Bueno Ferreira</div>
                <div class="plate-role">CLÍNICO GERAL · MÉDICO DO TRABALHO</div>
            </div>
            <div class="plate-crm">CRM-MS 15182</div>
        </div>
    </div>
</section>

<!-- STATS -->
<div class="stats">
    <div class="stat reveal">
        <div class="stat-n">2<span>+</span></div>
        <div class="stat-l">Anos de experiência clínica</div>
    </div>
    <div class="stat reveal d1">
        <div class="stat-n"><span>✓</span></div>
        <div class="stat-l">Registro CRM-MS verificado</div>
    </div>
    <div class="stat reveal d2">
        <div class="stat-n">24<span>h</span></div>
        <div class="stat-l">Retorno pós-consulta pelo WhatsApp</div>
    </div>
    <div class="stat reveal d3">
        <div class="stat-n">100<span>%</span></div>
        <div class="stat-l">Atendimento online &amp; seguro</div>
    </div>
</div>

<!-- SOBRE -->
<section class="section" id="sobre">
    <div class="about-grid">
        <div class="id-card reveal">
            <div class="id-logo-wrap">
                <img class="id-logo" src="~/images/tentativa4.jpg" alt="Dr. Cleiber Bueno — Logo">
            </div>
            <div class="id-header">
                <div class="id-av-row">
                    <img class="id-av" src="~/images/FotoCleibin.jpeg" alt="Dr. Cleiber">
                    <div>
                        <div class="id-name">Dr. Cleiber Bueno Ferreira</div>
                        <div class="id-role-lbl">CLÍNICO GERAL · MED. TRABALHO</div>
                    </div>
                </div>
            </div>
            <div class="id-body">
                <div class="id-field">
                    <div class="id-lbl">Registro</div>
                    <div class="id-val">CRM-MS 15182</div>
                </div>
                <div class="id-field">
                    <div class="id-lbl">Especialidade</div>
                    <div class="id-val">Médico Generalista — Clínica Geral e Medicina do Trabalho</div>
                </div>
                <div class="id-field">
                    <div class="id-lbl">Cidade</div>
                    <div class="id-val">Dourados – MS</div>
                </div>
                <div class="id-field">
                    <div class="id-lbl">Modalidade</div>
                    <div class="id-val">Telemedicina · Atendimento Online</div>
                </div>
            </div>
            <div class="id-crm">Registro verificável junto ao CRM-MS. Habilitado para o exercício da medicina.</div>
        </div>

        <div>
            <p class="eyebrow reveal">Sobre</p>
            <h2 class="section-h2 reveal d1">Medicina construída<br>pela <em>escuta</em></h2>
            <p class="body-p reveal d2">Olá, seja bem-vindo(a). Sou o Dr. Cleiber Bueno Ferreira, médico com experiência em clínica médica, urgência e emergência — incluindo atuação em pronto atendimento e sala vermelha, onde o diagnóstico preciso e a decisão rápida fazem toda a diferença.</p>
            <p class="body-p reveal d3">Natural de Assis (SP), morei em Campo Grande (MS) e atualmente resido em Dourados (MS), onde desenvolvo minha atividade profissional com foco em atendimento clínico de qualidade e acompanhamento integral dos pacientes.</p>
            <p class="body-p reveal d4">Atuo como Clínico Geral e Médico do Trabalho, realizando consultas, diagnósticos, solicitação e interpretação de exames, tratamento e acompanhamento de diversas condições clínicas.</p>
            <p class="body-p reveal d5">Meu objetivo não é apenas tratar uma doença, mas acompanhar cada paciente durante toda a jornada de saúde — com reavaliações, ajustes de tratamento e orientações sempre que necessário. Acredito que uma boa medicina é construída por meio da confiança, da comunicação clara e do acompanhamento próximo.</p>
        </div>
    </div>
</section>

<!-- COMO FUNCIONA -->
<section class="section how-section" id="como-funciona">
    <div class="how-header">
        <div>
            <p class="eyebrow reveal">Passo a passo</p>
            <h2 class="section-h2 reveal d1">Do agendamento<br>ao <em>acompanhamento</em></h2>
        </div>
        <p class="how-lead reveal d2">Desenvolvido para oferecer praticidade e segurança. Atendimento médico de qualidade sem você sair de casa.</p>
    </div>
    <div class="how-grid">
        <div class="how-card reveal">
            <div class="how-seq">1</div><div class="how-icon">📅</div>
            <h3>Agendamento pelo Formulário</h3>
            <p>Preencha seus dados abaixo. Entraremos em contato pelo WhatsApp para confirmar o horário.</p>
            <span class="how-tag">Rápido e sem complicação</span>
        </div>
        <div class="how-card reveal d1">
            <div class="how-seq">2</div><div class="how-icon">🎥</div>
            <h3>Consulta por Vídeo</h3>
            <p>Preferencial pelo Google Meet. Para quem preferir, videochamada pelo WhatsApp também disponível.</p>
            <span class="how-tag">Google Meet · WhatsApp</span>
        </div>
        <div class="how-card reveal d2">
            <div class="how-seq">3</div><div class="how-icon">🔍</div>
            <h3>Avaliação Médica</h3>
            <p>Análise completa de sintomas, histórico e medicamentos. Não precisa enviar exames antes da consulta.</p>
            <span class="how-tag">Diagnóstico individualizado</span>
        </div>
        <div class="how-card reveal d1">
            <div class="how-seq">4</div><div class="how-icon">📋</div>
            <h3>Documentos Digitais</h3>
            <p>Receitas, pedidos de exame, atestados e relatórios com validade legal conforme normas de telemedicina.</p>
            <span class="how-tag">Validade legal garantida</span>
        </div>
        <div class="how-card reveal d2">
            <div class="how-seq">5</div><div class="how-icon">💬</div>
            <h3>Suporte Pós-Consulta</h3>
            <p>Acompanhamento via WhatsApp a qualquer hora. Retorno em até 24 horas.</p>
            <span class="how-tag">Retorno em até 24h</span>
        </div>
        <div class="how-card reveal d3">
            <div class="how-seq">6</div><div class="how-icon">🔄</div>
            <h3>Consulta de Retorno</h3>
            <p>Em 15 a 30 dias após a consulta inicial, ajustado conforme doença, tratamento e evolução de cada caso.</p>
            <span class="how-tag">15 a 30 dias · Personalizado</span>
        </div>
    </div>
</section>

<!-- DOCUMENTOS -->
<section class="section docs-section" id="documentos">
    <div class="docs-grid">
        <div>
            <p class="eyebrow reveal">O que você recebe</p>
            <h2 class="section-h2 reveal d1">Documentos médicos<br><em>com validade digital</em></h2>
            <p class="body-p reveal d2" style="max-width:480px;">Emitidos quando há indicação médica, em conformidade com as normas brasileiras de telemedicina.</p>
            <ul class="docs-list">
                <li class="reveal d1"><div class="dico">💊</div>Receitas médicas</li>
                <li class="reveal d2"><div class="dico">🧪</div>Solicitações de exames complementares</li>
                <li class="reveal d3"><div class="dico">📄</div>Atestados médicos</li>
                <li class="reveal d4"><div class="dico">📑</div>Relatórios médicos</li>
                <li class="reveal d5"><div class="dico">📝</div>Orientações de tratamento e acompanhamento</li>
            </ul>
        </div>
        <div class="fu-card reveal d2">
            <h3>Acompanhamento próximo e contínuo</h3>
            <p>Meu compromisso não termina ao final da consulta. Estou disponível para esclarecer dúvidas e acompanhar sua evolução clínica durante todo o tratamento.</p>
            <p>O objetivo é garantir suporte em cada etapa da sua jornada de saúde — com atendimento ético, humanizado e baseado em evidências científicas.</p>
            <p>Será um prazer auxiliar você na busca por mais saúde, qualidade de vida e bem-estar.</p>
            <div class="fu-badge">📲 WhatsApp · Retorno em até 24h</div>
        </div>
    </div>
</section>

<!-- FORMULÁRIO DE AGENDAMENTO -->
<section class="section form-section" id="agendar">
    <div class="form-wrap">

        <!-- Lado esquerdo: explicação -->
        <div class="form-intro reveal">
            <p class="eyebrow">Agendar Consulta</p>
            <h2 class="section-h2">Preencha os dados<br>para <em>agendar</em></h2>
            <p class="form-intro-text">
                Preencha o formulário ao lado com calma e sem pressa.
                Assim que recebermos suas informações, o Dr. Cleiber entrará
                em contato pelo WhatsApp para confirmar o horário da sua consulta.
            </p>
            <ul class="form-checklist">
                <li>
                    <span class="fcheck-icon">✅</span>
                    <span>Agendamento simples e rápido</span>
                </li>
                <li>
                    <span class="fcheck-icon">✅</span>
                    <span>Confirmação pelo WhatsApp</span>
                </li>
                <li>
                    <span class="fcheck-icon">✅</span>
                    <span>Sem necessidade de enviar exames</span>
                </li>
                <li>
                    <span class="fcheck-icon">✅</span>
                    <span>Atendimento humanizado e seguro</span>
                </li>
            </ul>
        </div>

        <!-- Lado direito: formulário -->
        <div class="form-card reveal d2">

            <!-- Formulário visível -->
            <div id="formContent">
                <div class="form-card-header">
                    <div class="form-card-icon">📋</div>
                    <div>
                        <div class="form-card-title">Solicitação de Consulta</div>
                        <div class="form-card-sub">Todos os campos são obrigatórios</div>
                    </div>
                </div>

                <form asp-action="Agendar" asp-controller="Home" method="post" novalidate id="formAgendar">
                    @Html.AntiForgeryToken()

                    <!-- Nome -->
                    <div class="form-field">
                        <label class="form-label" for="NomePaciente">
                            👤 Nome completo
                        </label>
                        <input class="form-input"
                               type="text"
                               id="NomePaciente"
                               name="NomePaciente"
                               placeholder="Ex: Maria Aparecida Santos"
                               autocomplete="name"
                               required />
                        <span class="form-dica">Digite seu nome como está no documento.</span>
                    </div>

                    <!-- Idade -->
                    <div class="form-field">
                        <label class="form-label" for="IdadePaciente">
                            🎂 Idade
                        </label>
                        <input class="form-input form-input-small"
                               type="number"
                               id="IdadePaciente"
                               name="IdadePaciente"
                               placeholder="Ex: 58"
                               min="1"
                               max="120"
                               required />
                        <span class="form-dica">Apenas o número, em anos completos.</span>
                    </div>

                    <!-- WhatsApp -->
                    <div class="form-field">
                        <label class="form-label" for="NumeroContato">
                            📱 WhatsApp com DDD
                        </label>
                        <input class="form-input"
                               type="tel"
                               id="NumeroContato"
                               name="NumeroContato"
                               placeholder="Ex: (67) 99999-0000"
                               autocomplete="tel"
                               required />
                        <span class="form-dica">É por aqui que confirmaremos seu horário.</span>
                    </div>

                    <!-- Motivo -->
                    <div class="form-field">
                        <label class="form-label" for="MotivoConsulta">
                            🩺 Motivo da consulta
                        </label>
                        <textarea class="form-textarea"
                                  id="MotivoConsulta"
                                  name="MotivoConsulta"
                                  placeholder="Ex: Estou sentindo dor de cabeça com frequência e gostaria de avaliar minha pressão arterial..."
                                  rows="4"
                                  required></textarea>
                        <span class="form-dica">Descreva brevemente o que está sentindo ou o que deseja consultar.</span>
                    </div>

                    <button type="submit" class="form-submit" id="btnEnviar">
                        📋 Enviar Solicitação de Consulta
                    </button>

                    <p class="form-privacidade">
                        🔒 Seus dados são confidenciais e utilizados exclusivamente para o agendamento da consulta.
                    </p>
                </form>
            </div>

            <!-- Mensagem de sucesso (mostrada após envio) -->
            <div id="formSucesso" class="form-sucesso" style="display:none;">
                <div class="sucesso-icon">✅</div>
                <h3 class="sucesso-titulo">Solicitação enviada!</h3>
                <p class="sucesso-texto">
                    Recebemos seus dados com sucesso. Em breve o Dr. Cleiber
                    entrará em contato pelo WhatsApp para confirmar o horário da sua consulta.
                </p>
                <a href="https://wa.me/556798065995" target="_blank" rel="noopener" class="btn-g" style="display:inline-flex;margin-top:1.5rem;">
                    💬 Falar pelo WhatsApp agora
                </a>
            </div>

        </div>
    </div>
</section>

<!-- CTA -->
<section class="section cta-section">
    <div class="cta-inner">
        <p class="eyebrow reveal">Dúvidas? Fale diretamente</p>
        <h2 class="cta-h2 reveal d1">Prefere agendar<br><em>pelo WhatsApp?</em></h2>
        <p class="reveal d2">Sem problema! Você também pode entrar em contato diretamente pelo WhatsApp para agendar ou tirar dúvidas.</p>
        <div class="cta-btns reveal d3">
            <a href="https://wa.me/556798065995?text=Olá%2C%20Dr.%20Cleiber!%20Gostaria%20de%20agendar%20uma%20consulta."
               class="btn-wa" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" width="20" height="20">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.117.549 4.107 1.509 5.843L0 24l6.335-1.484A11.934 11.934 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818c-1.945 0-3.76-.528-5.315-1.446l-.38-.226-3.76.881.922-3.657-.249-.392A9.788 9.788 0 012.182 12c0-5.424 4.394-9.818 9.818-9.818 5.424 0 9.818 4.394 9.818 9.818 0 5.424-4.394 9.818-9.818 9.818z" fill="currentColor" />
                </svg>
                Agendar pelo WhatsApp
            </a>
            <a href="#sobre" class="btn-wa-g">Conhecer o médico</a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Máscara simples para telefone
        document.getElementById('NumeroContato').addEventListener('input', function (e) {
            let v = e.target.value.replace(/\D/g, '').slice(0, 11);
            if (v.length >= 7) {
                v = '(' + v.slice(0,2) + ') ' + v.slice(2,7) + '-' + v.slice(7);
            } else if (v.length >= 3) {
                v = '(' + v.slice(0,2) + ') ' + v.slice(2);
            } else if (v.length >= 1) {
                v = '(' + v;
            }
            e.target.value = v;
        });

        // Submit com feedback visual
        document.getElementById('formAgendar').addEventListener('submit', function (e) {
            const btn = document.getElementById('btnEnviar');
            btn.textContent = '⏳ Enviando...';
            btn.disabled = true;
            btn.style.opacity = '0.75';
            // O form faz POST normal — o controller redireciona de volta
            // Se quiser AJAX, remova o submit default e use fetch aqui
        });
    </script>
}
